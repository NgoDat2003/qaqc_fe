      "Bash(grep -E \"^ck-|^ship$|^retro$\")",
      "Bash(cp 'd:/work/maycha/qaqc-build/qaqc-fe/claude-engineer v2.16/.claude/hooks/session-state.cjs' d:/work/maycha/qaqc-build/qaqc-fe/.claude/hooks/session-state.cjs)",
      "Bash(cp 'd:/work/maycha/qaqc-build/qaqc-fe/claude-engineer v2.16/.claude/hooks/lib/session-state-manager.cjs' d:/work/maycha/qaqc-build/qaqc-fe/.claude/hooks/lib/session-state-manager.cjs)",
      "Bash(cp 'd:/work/maycha/qaqc-build/qaqc-fe/claude-engineer v2.16/.claude/hooks/lib/statusline-session-cache.cjs' d:/work/maycha/qaqc-build/qaqc-fe/.claude/hooks/lib/statusline-session-cache.cjs)",
      "Bash(node .claude/skills/markdown-novel-viewer/scripts/server.cjs --file \"plans/visuals/project-status.md\" --host 0.0.0.0 --open --foreground)",
      "Bash(npm install *)",
      "Bash(node \"C:/Users/ACER/.claude/scripts/set-active-plan.cjs\" \"plans/260514-1023-be-phase1-fe-alignment\")",
      "Bash(node __TRACKED_VAR__/.claude/scripts/set-active-plan.cjs d:/work/maycha/qaqc-build/qaqc-fe/plans/260514-1023-be-phase1-fe-alignment)",
      "Bash(curl http://localhost:3000/api/auth/me)",
      "Bash(git commit -m ' *)",
      "Bash(git commit *)",
      "Bash(gh pr create --title 'feat: BE Phase 1 → FE Alignment' --body ' *)",
      "Bash(where gh *)",
      "Bash(gh pr *)",
      "Bash(git fetch *)",
      "Bash(xargs grep *)",
      "Bash(npx next *)",
      "Bash(rm -rf .next)",
      "WebFetch(domain:uat.maycha.com.vn)",
      "Bash(git pull *)",
      "Bash(xargs ls *)",
      "Bash(gh api *)",
      "Bash(curl -s \"https://raw.githubusercontent.com/zuydd/vn-geo/main/json/provinces.json\")",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(f'Total provinces: {len\\(d\\)}'\\); print\\('Sample:', json.dumps\\(d[:2], ensure_ascii=False\\)\\)\")",
      "Bash(curl -s \"https://raw.githubusercontent.com/zuydd/vn-geo/main/json/tree.json\")",
      "Bash(python3 -c ' *)",
      "Bash(curl -s \"https://raw.githubusercontent.com/zuydd/vn-geo/main/json/tree.json\" -o d:/work/maycha/qaqc-build/qaqc-fe/src/lib/vn-geo/vn-tree.json)"
    ],
    "additionalDirectories": [
      "d:\\work\\maycha\\qaqc-build\\qaqc-fe\\src\\test"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-init.cjs"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/subagent-init.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/team-context-inject.cjs"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/cook-after-plan-reminder.cjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-state.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-state.cjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/dev-rules-reminder.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/usage-context-awareness.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/descriptive-name.cjs"
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scout-block.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/privacy-block.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskCreate|TaskUpdate|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/task-completed-handler.cjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-simplify-reminder.cjs"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/usage-context-awareness.cjs",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/statusline.cjs",
    "padding": 0
  }
}
